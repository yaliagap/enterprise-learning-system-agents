# CopilotKit runtime URL — points to the Next.js API route, NOT the FastAPI backend
# Default is /api/copilotkit (relative). Only override if deploying to a custom domain.
# NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=/api/copilotkit

# FastAPI backend URL (used by the Next.js route handler to proxy to the agent)
BACKEND_URL=http://localhost:8000
