# ── Local development ──────────────────────────────────────────────────────────
# Point directly at the local FastAPI backend (no Foundry proxy)
# NEXT_PUBLIC_AGENT_URL=http://localhost:8000/api/learn

# ── Foundry Hosted Agent (production) ─────────────────────────────────────────
# Routes frontend requests through the Next.js edge proxy → Foundry → container
NEXT_PUBLIC_AGENT_URL=/api/agent

FOUNDRY_AGENT_URL=https://<foundry-resource>.services.ai.azure.com/api/projects/<project>/agents/<agent-name>/endpoint/protocols/invocations?api-version=v1
FOUNDRY_API_KEY=your-foundry-api-key-here
