# Enterprise Learning System - environment variables
# Copy to .env - NEVER commit .env

# Azure AI Foundry (FoundryChatClient reads these natively)
# az login locally, or managed identity in production
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4o-mini

# IQ provider: false=mock fixtures, true=real Azure connectors
USE_REAL_IQ=false

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=enterprise-learning-system
ENABLE_INSTRUMENTATION=true

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# ChromaDB
CHROMA_DB_PATH=.chromadb
CHROMA_EF_MODEL=
